---
interface Props {
  planet: any;
}

const { planet } = Astro.props;

const fmtScore = (score: number | null | undefined, digits = 1) =>
  score === null || score === undefined ? 'N/A' : Number(score).toFixed(digits);

const fmtDistance = (distance: number | null | undefined) =>
  distance === null || distance === undefined ? 'unknown' : `${Number(distance).toFixed(1)} pc`;

const splitLabels = (raw: string | undefined) =>
  !raw || raw === 'none' ? [] : raw.split(',').map((x) => x.trim()).filter(Boolean);

const bars = [
  ['Magnetic Field', planet.score_magnetic_field],
  ['Habitable Zone', planet.score_habitable_zone],
  ['Thermal Plausibility', planet.score_thermal_plausibility],
  ['Rocky Surface', planet.score_rocky_likelihood],
  ['Stellar Stability', planet.score_stellar_stability],
  ['System Age', planet.score_system_age],
  ['Atmos. Retention', planet.score_atmosphere_hold],
  ['Data Confidence', planet.data_confidence_score],
];

const badges = [...splitLabels(planet.risk_flags), ...splitLabels(planet.missing_data).map((x) => `missing: ${x}`)].slice(0, 7);
---

<article class="border border-observatory-line-soft bg-observatory-panel/90 p-5 shadow-xl">
  <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
    <div>
      <p class="text-xs font-bold uppercase tracking-widest text-status-teal">Rank {String(planet.rank).padStart(2, '0')}</p>
      <h3 class="mt-1 font-serif text-2xl font-bold text-observatory-white">{planet.pl_name}</h3>
      <p class="text-xs text-observatory-muted">Host: {planet.hostname} · Distance: {fmtDistance(planet.sy_dist_pc)} · Discovery: {planet.disc_year || 'unknown'}</p>
    </div>
    <div class="border border-observatory-line-soft bg-observatory-bg/70 px-4 py-3 text-center">
      <span class="block text-[10px] uppercase tracking-widest text-observatory-dim">Vigil Score</span>
      <strong class="text-2xl text-status-teal">{fmtScore(planet.composite_score, 2)}</strong>
    </div>
  </div>

  <div class="my-4 grid grid-cols-2 gap-2 md:grid-cols-4">
    <div class="border border-observatory-line-soft p-3"><span class="block text-[10px] uppercase tracking-widest text-observatory-dim">Potential</span><strong>{fmtScore(planet.evidence_score, 2)}</strong></div>
    <div class="border border-observatory-line-soft p-3"><span class="block text-[10px] uppercase tracking-widest text-observatory-dim">Confidence</span><strong>{fmtScore(planet.data_confidence_score)}</strong></div>
    <div class="border border-observatory-line-soft p-3"><span class="block text-[10px] uppercase tracking-widest text-observatory-dim">Ceiling</span><strong>{fmtScore(planet.habitability_ceiling)}</strong></div>
    <div class="border border-observatory-line-soft p-3"><span class="block text-[10px] uppercase tracking-widest text-observatory-dim">Distance</span><strong>{fmtDistance(planet.sy_dist_pc)}</strong></div>
  </div>

  <p class="my-4 border-l-2 border-status-teal pl-3 font-serif text-sm leading-7 text-observatory-text">
    {planet.rank_explanation || 'Balanced candidate with ranking driven by measured potential, confidence, and physical caps.'}
  </p>

  <div class="mb-4 flex flex-wrap gap-2">
    {badges.length ? badges.map((badge) => <span class="rounded-full border border-status-amber/30 bg-status-amber/10 px-2 py-1 text-[10px] text-status-amber">{badge}</span>) : <span class="rounded-full border border-status-teal/30 bg-status-teal/10 px-2 py-1 text-[10px] text-status-teal">no major flags</span>}
  </div>

  <div class="grid gap-x-6 md:grid-cols-2">
    {bars.map(([label, score]) => {
      const numericScore = score === null || score === undefined ? null : Number(score);
      const width = numericScore === null ? 0 : Math.max(0, Math.min(100, numericScore * 10));
      return (
        <div class="mb-2 grid grid-cols-[150px_1fr_42px] items-center gap-2">
          <span class="text-[10px] uppercase tracking-wider text-observatory-dim">{label}</span>
          <div class="h-1.5 overflow-hidden rounded-full bg-observatory-panel-3">
            <div class="h-full rounded-full bg-status-teal" style={`width: ${width}%`}></div>
          </div>
          <span class="text-right text-xs font-bold text-status-teal">{fmtScore(numericScore)}</span>
        </div>
      );
    })}
  </div>
</article>
